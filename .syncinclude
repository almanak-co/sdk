.dockerignore

# --- Repo and tooling config ---
.gitignore
.python-version
.almanak-code-version
.env.example

# --- Sync infrastructure (publish the allowlist itself for transparency) ---
.syncinclude

# --- Core SDK package ---
almanak/

# --- Examples, skills ---
examples/
skills/

