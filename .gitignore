*__pycache__/
.DS_Store
node_modules/
/docs_output
/almanak/sdk/dist/
.env
.power-env

/marcia-test-folder/
/almanak-test-folder/
/example-results-data/
example-data/
.aider*
build
almanak.egg-info/
dist/

local_storage/
# Local artifacts
venv/
# pytest-split per-test timings. Generated by `make test-ci STORE_DURATIONS=...`
# (post-merge Main run) and cached/restored across CI for duration-balanced
# shard splitting — never committed; regenerated by CI.
.test_durations
# Strategy-scoped SQLite stores (VIB-3761 folder-scoping). Match in any
# subdirectory so committed reference DBs cannot regress (VIB-3864). Sample
# DB dumps for accountant-test reports stay LOCAL — never committed.
**/almanak_state.db
**/almanak_state.db-shm
**/almanak_state.db-wal
**/almanak_state.db.gw.lock
**/almanak_state.db.*
# Runner deferred-write tape — a run-specific, machine-specific accounting
# replay log written under a strategy folder. Never committed (leaks
# deployment_id / tx_hash and pollutes consumer checkouts). VIB-5032.
**/accounting_deferred.jsonl
almanak_copy_ledger.db
# Accountant Test reference DB backups (kept locally; never committed).
docs/internal/AccountantTest-baseline/db-backups/
.almanak/sdk.json
scripts/contracts.db
almanak/.dashboard_events.json
probe/

# Native binaries (downloaded at build time)
almanak/bin/almanak-code-*

# LLM docs (generated during CI build from mkdocs)
almanak/llms/llms-full.txt

# Generated docs — produced by scripts/docs/ generators and mdclick at build
# time. Never commit; ``make docs`` regenerates them before ``mkdocs build``.
# See scripts/docs/generate_connector_matrix.py,
# scripts/docs/generate_chain_table.py, and the ``docs-cli`` Makefile target.
docs/api/connectors/index.md
docs/api/connectors/*.md
!docs/api/connectors/base.md
docs/chains.md
docs/chains/*.md
docs/cli/*.md

# Build script temp dirs
.bin_stash/
.wheel_staging/

# MkDocs build output
/site/
/site-llms/

# Coverage reports
coverage-html/
coverage.xml
test-results.xml
.coverage

# Automation scripts runtime artifacts
logs/
scripts/kitchenloop/kitchenloop.log
scripts/pr-manager/pr-manager.log
scripts/pr-manager/state.json
docs/internal/notes/.tmp/
# Guard: no root-level notes/. Canonical scratch + notes live under
# docs/internal/notes/ (durable .md tracked; docs/internal/notes/.tmp/ ignored
# above). This keeps the repo root clean if a tool ever writes here by accident.
notes/

# Smoke-test runtime output (scripts/smoke-test-all.sh, smoke-test-batch.sh)
/results/

# Solana test-validator ledger
test-ledger/

# Local Claude artifacts
.claude/worktrees/
.claude/projects/

# Editor / IDE
.vscode/

# Video build output
videos/out/

# Nightly test output
tests/visual/nightly/output/

# Stray uv.lock files in strategy subdirectories (not part of the SDK package)
strategies/incubating/*/uv.lock
strategies/demo/*/uv.lock

# KitchenLoop runtime artifacts
.kitchenloop/

# Strategy run logs (regenerable, can grow large)
strategies/**/run-*.jsonl

# AI discussion transcripts (auto-generated by discussion-moderator skill)
scripts/ai-discussion/conversations/
# any files containing secrets
secrets.yaml
.env.nightly
platform-plugins/almanak_platform_plugins.egg-info/
.claude/scheduled_tasks.lock

# Quant User evidence bundles (run artifacts; README + pipe changelog tracked)
docs/internal/quant-user-runs/*
!docs/internal/quant-user-runs/README.md
!docs/internal/quant-user-runs/changelog.html
# Durable batch-run tooling IS tracked. Internal-only: docs/internal/ is never in
# .syncinclude, so this ships in the private repo but is NOT published to the public
# mirror. Run artifacts inside _harness/ (e.g. __pycache__) stay ignored.
!docs/internal/quant-user-runs/_harness/
docs/internal/quant-user-runs/_harness/__pycache__/
