local_storage/
# Local artifacts
venv/
# Strategy-scoped SQLite stores (VIB-3761 folder-scoping). Match in any
# subdirectory so committed reference DBs cannot regress (VIB-3864). Sample
# DB dumps for accountant-test reports stay LOCAL — never committed.
**/almanak_state.db
**/almanak_state.db-shm
**/almanak_state.db-wal
**/almanak_state.db.gw.lock
**/almanak_state.db.*
almanak_copy_ledger.db
# Accountant Test reference DB backups (kept locally; never committed).
docs/internal/AccountantTest-baseline/db-backups/
.almanak/sdk.json
scripts/contracts.db
almanak/.dashboard_events.json
probe/

# Native binaries (downloaded at build time)
almanak/bin/almanak-code-*

# LLM docs (generated during CI build from mkdocs)
almanak/llms/llms-full.txt

# Build script temp dirs
.bin_stash/
.wheel_staging/

# MkDocs build output
/site/
/site-llms/

# Coverage reports
coverage-html/
coverage.xml
test-results.xml
.coverage

# Automation scripts runtime artifacts
logs/
scripts/kitchenloop/kitchenloop.log
scripts/pr-manager/pr-manager.log
scripts/pr-manager/state.json
notes/.tmp/

# Solana test-validator ledger
test-ledger/

# Local Claude artifacts
.claude/worktrees/
.claude/projects/

# Video build output
videos/out/

# Nightly test output
tests/visual/nightly/output/

# Stray uv.lock files in strategy subdirectories (not part of the SDK package)
strategies/incubating/*/uv.lock
strategies/demo/*/uv.lock

# KitchenLoop runtime artifacts
.kitchenloop/
# any files containing secrets
secrets.yaml
.env.nightly
platform-plugins/almanak_platform_plugins.egg-info/
