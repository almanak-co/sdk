# Platform Sweep Runner container
#
# Cloud Run Job entrypoint used by the platform backend. The job clones a user's
# strategy repo at a pinned commit, runs one SDK PnL backtest per parameter
# combination in the requested sweep grid, uploads the ranked JSON result to
# GCS, and calls the platform completion callback.
#
# Build:
#   docker build -f almanak/services/backtest/Dockerfile.platform-sweep-runner -t almanak-sweep-runner:local .

# ---------------------------------------------------------------------------
# Stage 1: Build
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS builder

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock PYPI.md ./

RUN uv sync --frozen --no-cache --no-dev --no-install-project --extra platform-runner

COPY almanak ./almanak

RUN uv sync --frozen --no-cache --no-dev --extra platform-runner

# ---------------------------------------------------------------------------
# Stage 2: Runtime
# ---------------------------------------------------------------------------
FROM python:3.12-slim AS runtime

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 almanak && \
    useradd --uid 1000 --gid 1000 --create-home --shell /bin/bash almanak && \
    mkdir -p /workspace/strategy && \
    chown -R almanak:almanak /app /workspace

COPY --from=builder --chown=almanak:almanak /app/.venv /app/.venv
COPY --from=builder --chown=almanak:almanak /app/almanak /app/almanak
COPY --from=builder --chown=almanak:almanak /app/pyproject.toml /app/
# The sweep entrypoint reuses the backtest runner's clone / discovery /
# callback machinery, imported as `scripts.platform_backtest_runner`.
COPY --chown=almanak:almanak scripts/__init__.py scripts/platform_backtest_runner.py /app/scripts/
COPY --chown=almanak:almanak scripts/platform_sweep_runner.py /app/runner.py

USER almanak

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app"
ENV ALMANAK_ENABLE_BACKTESTING=1
# Flush stdout/stderr immediately so Cloud Run Job logs are not lost to
# block-buffering when the container exits.
ENV PYTHONUNBUFFERED=1

CMD ["python", "/app/runner.py"]
